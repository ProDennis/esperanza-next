rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite lectura pública para el sitio web
    match /settings/contact_info {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in ["dennisbusiness2016@gmail.com", "2020.gloriavasquez@gmail.com"];
    }
    
    match /products/{product} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email in ["dennisbusiness2016@gmail.com", "2020.gloriavasquez@gmail.com"];
    }
  }
}
